<!DOCTYPE html>
<html>
  <head>
    <title>My VR World</title>
    <script src="https://aframe.io/releases/1.4.0/aframe.min.js"></script>
  </head>

  <body>
    <a-scene>

      <a-assets>
        <a-asset-item id="mymodel" src="yourmodel.glb"></a-asset-item>
      </a-assets>

      <a-sky color="lightblue"></a-sky>
      <a-plane rotation="-90 0 0" width="20" height="20" color="green"></a-plane>

      <a-entity 
        gltf-model="#mymodel"
        position="0 0 -3"
        scale="1 1 1">
      </a-entity>

      <a-camera position="0 1.6 0"></a-camera>

    </a-scene>
  </body>
</html>
